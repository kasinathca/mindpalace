{
  "name": "mindpalace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Web-based bookmark management and content preservation system",
  "scripts": {
    "dev": "concurrently --names \"API,WORKER,WEB\" --prefix-colors \"cyan,yellow,magenta\" \"pnpm --filter api run dev\" \"pnpm --filter api run worker:dev\" \"pnpm --filter web run dev\"",
    "build": "pnpm --filter shared run build && pnpm --filter api run build && pnpm --filter web run build",
    "lint": "pnpm -r --parallel run lint",
    "lint:fix": "pnpm -r --parallel run lint:fix",
    "type-check": "pnpm -r --parallel run type-check",
    "test": "pnpm -r run test",
    "test:unit": "pnpm -r run test:unit",
    "test:integration": "pnpm --filter api run test:integration",
    "test:e2e": "pnpm --filter web run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7"
    }
  }
}

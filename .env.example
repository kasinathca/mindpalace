# ─────────────────────────────────────────────────────────────────────────────
# Mind Palace — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in every value marked [REQUIRED].
# The API validates all variables at startup using Zod (apps/api/src/config/env.ts).
# The server will refuse to start and print clear errors if anything is wrong.
# ─────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────
# APPLICATION
# ──────────────────────────────
# Runtime environment. Change to "production" when deploying.
NODE_ENV=development

# Port the Express API server will listen on.
PORT=3000

# ──────────────────────────────
# DATABASE (PostgreSQL)
# ──────────────────────────────
# [REQUIRED] Full PostgreSQL connection string.
# For local Docker setup: use the values defined in docker-compose.yml.
DATABASE_URL=postgresql://mp_user:mp_pass@localhost:5432/mindpalace

# ──────────────────────────────
# CACHE & QUEUE (Redis)
# ──────────────────────────────
# [REQUIRED] Redis connection URL.
# For local Docker setup: use the default below.
REDIS_URL=redis://localhost:6379

# ──────────────────────────────
# AUTHENTICATION (JWT)
# ──────────────────────────────
# [REQUIRED] Secret keys for signing JWT tokens.
# MUST be at least 32 characters long each.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_A_RANDOM_SECRET_AT_LEAST_32_CHARS_LONG
JWT_REFRESH_SECRET=REPLACE_WITH_A_DIFFERENT_RANDOM_SECRET_AT_LEAST_32_CHARS_LONG

# How long access tokens stay valid (short — 15 minutes recommended).
JWT_ACCESS_EXPIRY=15m

# How long refresh tokens stay valid (7 days recommended).
JWT_REFRESH_EXPIRY=7d

# ──────────────────────────────
# EMAIL (SMTP)
# ──────────────────────────────
# [REQUIRED] SMTP server connection details (used for password reset emails).
# For development you can use your Gmail account:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your.email@gmail.com
#   SMTP_PASS=your-gmail-app-password  (generate at myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-gmail-app-password

# [REQUIRED] The "From" address shown in outgoing emails.
EMAIL_FROM=noreply@mindpalace.local

# ──────────────────────────────
# FILE STORAGE
# ──────────────────────────────
# Directory where thumbnails and favicons are saved.
# Relative to the api/ package root.
UPLOADS_DIR=./uploads

# Maximum file size for bookmark HTML import uploads (in megabytes).
MAX_FILE_SIZE_MB=10

# ──────────────────────────────
# CORS
# ──────────────────────────────
# [REQUIRED] The exact origin of the frontend. No trailing slash.
# For local development this is the Vite dev server URL.
CORS_ORIGIN=http://localhost:5173

# ──────────────────────────────
# RATE LIMITING
# ──────────────────────────────
# Time window for rate limiting in milliseconds (default: 15 minutes).
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per IP per window (default: 100).
RATE_LIMIT_MAX_REQS=100

# ──────────────────────────────
# SECURITY
# ──────────────────────────────
# bcrypt cost factor for password hashing.
# 12 is the recommended minimum. Use 4 in tests only (set in vitest.config.ts).
BCRYPT_ROUNDS=12

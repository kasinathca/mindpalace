{
  "name": "@mindpalace/api",
  "version": "1.0.0",
  "private": true,
  "description": "Mind Palace — REST API + background workers",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "worker:dev": "tsx watch src/workers/worker.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "worker:start": "node dist/workers/worker.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest watch --config vitest.unit.config.ts",
    "test:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "db:migrate": "prisma migrate dev",
    "db:migrate:test": "prisma migrate deploy",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@mindpalace/shared": "workspace:*",
    "@mozilla/readability": "^0.5.0",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.0",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "express-rate-limit": "^7.3.0",
    "got": "^14.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "isomorphic-dompurify": "^2.15.0",
    "jsdom": "^24.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.11",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.0",
    "sharp": "^0.33.4",
    "striptags": "^3.2.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^2.0.0",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}

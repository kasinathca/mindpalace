# ─────────────────────────────────────────────────────────────────────────────
# .env.test.example — Required environment variables for integration tests
#
# Copy this file to .env.test and fill in the values for your local setup:
#   cp .env.test.example .env.test
#
# Then load it before running integration tests:
#   export $(cat .env.test | xargs) && pnpm run test:integration
#
# The SMTP_*, EMAIL_FROM, and CORS_ORIGIN variables are injected automatically
# via vitest.config.ts — you only need the infrastructure vars below.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL — must point to a test database (NOT your dev database).
# Run `pnpm run db:migrate:test` to apply migrations to this database first.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mindpalace_test

# Redis — the test suite uses the real Redis client via BullMQ.
REDIS_URL=redis://localhost:6379

# JWT secrets — any string >= 32 characters works for local tests.
JWT_ACCESS_SECRET=test-access-secret-that-is-at-least-32-chars
JWT_REFRESH_SECRET=test-refresh-secret-that-is-at-least-32-chars
